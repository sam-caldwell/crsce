{
  "version": 3,
  "configurePresets": [
    {
      "name": "llvm-debug",
      "displayName": "LLVM (Homebrew) Debug",
      "description": "Debug with Homebrew clang/llvm and C++23 (Metal optional)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/llvm-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_OBJCXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_OSX_SYSROOT": "$env{SDKROOT}",
        "CMAKE_CXX_CLANG_TIDY": "/opt/homebrew/opt/llvm/bin/clang-tidy;-warnings-as-errors=*;--header-filter=^(?!.*metal-cpp).*;--extra-arg=-w;--extra-arg=-fdiagnostics-show-option;--extra-arg=-DCRSCE_CLANG_TIDY=1",
        "CRSCE_ENABLE_METAL": "ON",
        "CRSCE_METAL_CPP_INCLUDE": "$env{CRSCE_METAL_CPP_INCLUDE}"
      }
    },
    {
      "name": "llvm-release",
      "displayName": "LLVM (Homebrew) Release",
      "description": "Release with Homebrew clang/llvm and C++23 (Metal optional)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/llvm-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_OBJCXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_OSX_SYSROOT": "$env{SDKROOT}",
        "CMAKE_CXX_CLANG_TIDY": "/opt/homebrew/opt/llvm/bin/clang-tidy;-warnings-as-errors=*;--header-filter=^(?!.*metal-cpp).*;--extra-arg=-w;--extra-arg=-fdiagnostics-show-option;--extra-arg=-DCRSCE_CLANG_TIDY=1",
        "CRSCE_ENABLE_METAL": "ON",
        "CRSCE_METAL_CPP_INCLUDE": "$env{CRSCE_METAL_CPP_INCLUDE}"
      }
    },
    {
      "name": "arm64-release",
      "displayName": "ARM64 Release",
      "description": "ARM64 Release (Metal optional)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/arm64-release",
      "architecture": { "value": "arm64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_OBJCXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CRSCE_ENABLE_METAL": "ON",
        "CRSCE_METAL_CPP_INCLUDE": "$env{CRSCE_METAL_CPP_INCLUDE}"
      }
    },
    {
      "name": "metal",
      "displayName": "Metal (ObjC++ shim)",
      "description": "Metal-enabled build in build/metal using AppleClang for ObjC++ shim",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/metal",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OBJCXX_COMPILER": "/usr/bin/clang++",
        "CRSCE_ENABLE_METAL": "ON"
      }
    },
    {
      "name": "constraint",
      "displayName": "Constraint Solver",
      "description": "Constraint-driven solver build in build/constraint (compile-time select)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/constraint",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CRSCE_SOLVER_CONSTRAINT": "ON"
      }
    }
  ]
}
