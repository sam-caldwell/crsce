{
  "version": 3,
  "configurePresets": [
    {
      "name": "amd64-release",
      "displayName": "AMD64 Release",
      "description": "Configure for AMD64 with optimizations and SHA-NI extensions.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/amd64-release",
      "architecture": {
        "value": "x86_64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_FLAGS": "-O3 -flto=thin -march=x86-64-v3 -msha",
        "CMAKE_C_FLAGS": "-O3 -flto=thin -march=x86-64-v3 -msha",
        "CMAKE_ASM_FLAGS": "-march=x86-64-v3 -msha",
        "CMAKE_EXE_LINKER_FLAGS": "-flto=thin"
      }
    },
    {
      "name": "arm64-release",
      "displayName": "ARM64 Release",
      "description": "Configure for ARM64 with optimizations and SHA-2 extensions.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/arm64-release",
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_FLAGS": "-O3 -flto=thin -march=armv8.2-a+sha2 -mtune=apple-m1",
        "CMAKE_C_FLAGS": "-O3 -flto=thin -march=armv8.2-a+sha2 -mtune=apple-m1",
        "CMAKE_ASM_FLAGS": "-march=armv8.2-a+sha2 -mtune=apple-m1",
        "CMAKE_EXE_LINKER_FLAGS": "-flto=thin"
      }
    },
    {
      "name": "llvm-release",
      "displayName": "LLVM (Homebrew) Release",
      "description": "Release with Homebrew clang/llvm, C++23, and -O3",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/llvm-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_OSX_SYSROOT": "$env{SDKROOT}",
        "CMAKE_CXX_FLAGS": "-O3 -flto=thin",
        "CMAKE_C_FLAGS": "-O3 -flto=thin",
        "CMAKE_EXE_LINKER_FLAGS": "-flto=thin",
        "CMAKE_CXX_CLANG_TIDY": "/opt/homebrew/opt/llvm/bin/clang-tidy;-warnings-as-errors=*;--header-filter=.*;--extra-arg=-w;--extra-arg=-fdiagnostics-show-option"
      }
    },
    {
      "name": "llvm-pgo-gen",
      "displayName": "LLVM PGO Instrumented",
      "description": "Release build with PGO instrumentation (generate profile data).",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/llvm-pgo-gen",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_OSX_SYSROOT": "$env{SDKROOT}",
        "CMAKE_CXX_FLAGS": "-O3 -flto=thin -fprofile-generate=${sourceDir}/build/profdata",
        "CMAKE_C_FLAGS": "-O3 -flto=thin -fprofile-generate=${sourceDir}/build/profdata",
        "CMAKE_EXE_LINKER_FLAGS": "-flto=thin -fprofile-generate=${sourceDir}/build/profdata"
      }
    },
    {
      "name": "llvm-pgo-use",
      "displayName": "LLVM PGO Optimized",
      "description": "Release build using PGO profile data for branch prediction optimization.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/llvm-pgo-use",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_OSX_SYSROOT": "$env{SDKROOT}",
        "CMAKE_CXX_FLAGS": "-O3 -flto=thin -fprofile-use=${sourceDir}/build/profdata/default.profdata",
        "CMAKE_C_FLAGS": "-O3 -flto=thin -fprofile-use=${sourceDir}/build/profdata/default.profdata",
        "CMAKE_EXE_LINKER_FLAGS": "-flto=thin -fprofile-use=${sourceDir}/build/profdata/default.profdata"
      }
    }
  ]
}
